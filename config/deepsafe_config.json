{
  "api_url": "http://localhost:8000",
  "media_types": {
    "image": {
      "model_endpoints": {
        "universalfakedetect": "http://wholesome-alignment.railway.internal:5004/predict"
      },
      "health_endpoints": {
        "universalfakedetect": "http://wholesome-alignment.railway.internal:5004/health"
      },
      "supported_extensions": [
        "*.jpg",
        "*.jpeg",
        "*.png",
        "*.webp",
        "*.bmp",
        "*.gif",
        "*.tiff",
        "*.tif"
      ]
    }
  },
  "default_output_dir_base": "./deepsafe_test_results",
  "default_threshold": 0.01,
  "default_ensemble_method": "average",
  "default_api_timeout_seconds": 90,
  "default_model_timeout_seconds_video": 1800,
  "memory_optimization": true,
  "default_max_workers_batch": 1
}
